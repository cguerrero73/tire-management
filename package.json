{
  "name": "tire-management",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:eam": "tsc -p tsconfig.eam.json",
    "build:all": "npm run build && npm run build:eam",
    "deploy:local": "npm run build:all && cp -r dist-eam/* dist/browser/ 2>/dev/null || mkdir -p dist/browser && cp -r dist-eam/* dist/browser/",
    "deploy:check": "ls -la dist/browser/ 2>/dev/null && ls -la dist-eam/ 2>/dev/null"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
}
