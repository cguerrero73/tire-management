{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-eam",
    "declaration": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/eam/**/*.ts", "src/core/**/*.ts", "src/app/core/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/app/**/*.ts"]
}
